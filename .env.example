APP_NAME=DreamScore
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.com
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production DB: switch DB_CONNECTION=mysql and fill the credentials below.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=dreamscore
# DB_USERNAME=
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production: SESSION_SECURE_COOKIE=true (HTTPS-only cookies)
SESSION_SECURE_COOKIE=false

# Production SMTP — replace with your real provider (Mailgun, SES, Postmark, etc.)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Authorize.Net (Accept.js + webhooks) ─────────────────────────────
# Set AUTHORIZE_NET_ENV=production and swap in your live merchant keys for go-live.
# Signature key: Account → Settings → API Credentials & Keys → New Signature Key
AUTHORIZE_NET_ENV=sandbox
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_CLIENT_KEY=
AUTHORIZE_NET_SIGNATURE_KEY=

# ─── GoHighLevel webhooks ─────────────────────────────────────────────
GHL_POPUP_WEBHOOK=
GHL_ONBOARDING_WEBHOOK=
GHL_LEAD_WEBHOOK=
# Falls back to GHL_ONBOARDING_WEBHOOK when blank
GHL_PAYMENT_WEBHOOK=

# ─── Credit Repair Cloud ──────────────────────────────────────────────
# CRC dashboard → My Company → API & Automations → API Credentials
CRC_API_KEY=
CRC_SECRET_KEY=
CRC_BASE_URL=https://app.creditrepaircloud.com/api
